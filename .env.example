# Gates of Lodore Permit Bot — copy to .env and fill in your values
# Not all variables are required; only set the notification methods you use.

# ---------------------------------------------------------------------------
# Email (SMTP) — e.g. Gmail with App Password
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=recipient@example.com

# ---------------------------------------------------------------------------
# Pushover (mobile push)
# ---------------------------------------------------------------------------
PUSHOVER_USER=your-pushover-user-key
PUSHOVER_TOKEN=your-pushover-app-token

# ---------------------------------------------------------------------------
# Slack
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ---------------------------------------------------------------------------
# Twilio SMS
# ---------------------------------------------------------------------------
TWILIO_SID=your-twilio-account-sid
TWILIO_AUTH=your-twilio-auth-token
TWILIO_FROM=+1234567890
TWILIO_TO=+1234567890

# ---------------------------------------------------------------------------
# Discord
# ---------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# ---------------------------------------------------------------------------
# Optional: logging (default is INFO)
# ---------------------------------------------------------------------------
# LOG_LEVEL=DEBUG
